      "10. resolution_boost",
      "11. evidence_type (verified > inferred)",
      "12. importance_freshness",
      "13. inhibition_of_return (-5% per recent session, max -15%)",
      "14. curiosity_boost (dead memory exploration)",
      "15. goal_relevance (focus goal boost)",
      "16. dimensional_boost (5W context match)",
      "17. kg_expansion (gated: probe first 3 results)",
      "18. spreading_activation (fan effect dampened, gated: probe seed)",
